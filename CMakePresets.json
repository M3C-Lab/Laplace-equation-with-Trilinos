{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "Trilinos_ROOT": "/home/xuanming/lib/Trilinos",
        "Kokkos_LAUNCH_COMPILER": "OFF",
        "CMAKE_CXX_COMPILER": "/home/xuanming/lib/Trilinos/bin/nvcc_wrapper"
      },
      "environment": {
        "NVCC_WRAPPER_DEFAULT_COMPILER": "/home/xuanming/lib/mpich-4.3.2/bin/mpicxx"
      }
    },
    {
      "name": "backend-openmp",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-openmp",
      "cacheVariables": {
        "LAPLACE_FEM_BACKEND": "OPENMP"
      }
    },
    {
      "name": "backend-cuda",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "${sourceDir}/build-cuda",
      "cacheVariables": {
        "LAPLACE_FEM_BACKEND": "CUDA"
      }
    },
    {
      "name": "cpu",
      "inherits": "backend-openmp",
      "displayName": "CPU",
      "binaryDir": "${sourceDir}/build-cpu",
      "cacheVariables": {
        "LAPLACE_FEM_ENABLE_OPENMP": "OFF"
      }
    },
    {
      "name": "openmp",
      "inherits": "backend-openmp",
      "displayName": "OpenMP"
    },
    {
      "name": "cuda",
      "inherits": "backend-cuda",
      "displayName": "CUDA"
    }
  ],
  "buildPresets": [
    {
      "name": "cpu",
      "configurePreset": "cpu"
    },
    {
      "name": "openmp",
      "configurePreset": "openmp"
    },
    {
      "name": "cuda",
      "configurePreset": "cuda"
    }
  ]
}
